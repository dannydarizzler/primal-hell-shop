# Kopiere diese Datei zu ".env" und trag deine echten Werte ein
# WICHTIG: .env NIEMALS committen oder teilen!

# Aus PayPal Developer Dashboard -> Apps & Credentials
PAYPAL_CLIENT_ID=deine_sandbox_client_id_hier
PAYPAL_CLIENT_SECRET=dein_sandbox_secret_hier

# "sandbox" zum Testen, "live" wenn es echt losgeht
PAYPAL_ENV=sandbox

# Port für den lokalen Server (Railway setzt das automatisch selbst)
PORT=3000

# Zufälliger, langer String zum Signieren der Login-Session-Cookies.
# Frei erfunden, z.B. mit: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# Muss EXAKT mit dem Wert übereinstimmen, den du beim Bot als BOT_SYNC_SECRET einträgst.
# Wird sowohl für den Bot->Shop Coin-Sync als auch für Admin-Commands (Items einsehen/einlösen) genutzt.
BOT_SYNC_SECRET=change_me_too_same_value_as_bot
